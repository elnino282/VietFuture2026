APP_NAME="ACM AI Chatbox"
API_PREFIX=/api/v1/ai

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b
EMBEDDING_MODEL=nomic-embed-text

OLLAMA_THINK=false

CHROMA_DIR=./chroma_db
DATA_DIR=./data
COLLECTION_NAME=acm_knowledge

CHUNK_SIZE=650
CHUNK_OVERLAP=100

DEFAULT_TOP_K=4
MAX_CONTEXT_CHARS=2000
MAX_DISTANCE_THRESHOLD=0.42
# MIN_RETRIEVAL_SCORE is intentionally unset: Chroma returns distance, so MAX_DISTANCE_THRESHOLD is used.
# MIN_RETRIEVAL_SCORE=
DEBUG_RAG=false

NUM_PREDICT=384
NUM_CTX=4096

TEMPERATURE=0.05
TOP_K=10
TOP_P=0.7
REPEAT_PENALTY=1.1

KEEP_ALIVE=30m
