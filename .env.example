# MySQL / Database
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=quanlymuavu
MYSQL_USER=springuser
MYSQL_PASSWORD=springpass
DB_URL=jdbc:mysql://localhost:3307/quanlymuavu
DB_USER=springuser
DB_PASS=springpass

# RabbitMQ
RABBITMQ_DEFAULT_USER=rabbituser
RABBITMQ_DEFAULT_PASS=rabbitpass
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_URL=http://localhost:9000

# Security / JWT
SPRING_PROFILES_ACTIVE=dev
JWT_SIGNER_KEY=supersecretkeyplaceholder64characterslongmustbe64byteslongforhs512!
JWT_JWKS_URI=http://localhost:8081/api/v1/auth/.well-known/jwks.json
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000

# Integrations / APIs
GOOGLE_CLIENT_ID=
APP_AI_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
WEATHER_API_KEY=

# Gateway & Frontend Configs
GATEWAY_PORT=8000
MONOLITH_URI=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
